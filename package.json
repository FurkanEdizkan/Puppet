{
	"name": "puppet",
	"version": "1.0.0",
	"description": "Create and manage notes for movies, TV series, books, anime, games, research papers, and more with automatic metadata from various APIs.",
	"main": "main.js",
	"type": "module",
	"author": "FurkanEdizkan",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/FurkanEdizkan/Puppet.git"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"media",
		"metadata",
		"movies",
		"books",
		"anime",
		"games"
	],
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"license": "0-BSD",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^3.1.1",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1",
		"vitest": "^3.1.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
